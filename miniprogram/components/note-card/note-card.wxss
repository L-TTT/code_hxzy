.note-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(145deg, rgba(26, 26, 46, 0.95), rgba(15, 16, 35, 0.9));
  border: 1rpx solid rgba(201, 169, 110, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
  animation: fadeInUp 0.6s ease-out;
}

.note-card:active {
  transform: scale(0.95);
}

.note-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.symbol {
  font-size: 32rpx;
  line-height: 1;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.title {
  font-size: 24rpx;
  color: #FFF8F0;
  font-weight: 500;
  text-align: center;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date {
  font-size: 20rpx;
  color: #C9A96E;
  opacity: 0.8;
}

.photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

/* Type-specific styles */
.note-birthday .symbol {
  color: #FF6B6B;
}

.note-anniversary .symbol {
  color: #B76E79;
}

.note-daily .symbol {
  color: #9B8EC1;
}

.note-standard .symbol {
  color: #C9A96E;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
