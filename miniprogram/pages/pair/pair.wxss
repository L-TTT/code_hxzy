.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: rgba(15, 16, 35, 0.8);
  flex-shrink: 0;
}

.nav-left {
  padding: 16rpx;
}

.back-icon {
  font-size: 44rpx;
  color: var(--gold);
  font-weight: 300;
}

.nav-title {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 500;
  letter-spacing: 4rpx;
}

.nav-right {
  width: 60rpx;
}

.pair-scroll {
  flex: 1;
  overflow: hidden;
}

.pair-body {
  padding: 48rpx 48rpx;
}

.pair-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.pair-emoji {
  font-size: 80rpx;
}

.pair-subtitle {
  font-size: 28rpx;
  color: var(--cream);
  opacity: 0.7;
  letter-spacing: 2rpx;
}

.tab-bar {
  display: flex;
  background: rgba(26, 26, 46, 0.6);
  border-radius: 16rpx;
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  overflow: hidden;
  position: relative;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
}

.tab-item.active .tab-text {
  color: var(--ink);
  font-weight: 600;
}

.tab-text {
  font-size: 28rpx;
  color: rgba(255, 248, 240, 0.5);
  letter-spacing: 2rpx;
}

.tab-indicator {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: calc(50% - 4rpx);
  height: calc(100% - 8rpx);
  background: var(--gold);
  border-radius: 12rpx;
  transition: transform 0.3s ease;
  pointer-events: none;
}

.invite-panel,
.join-panel {
  margin-top: 48rpx;
}

.invite-desc,
.join-desc {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
}

.desc-text {
  font-size: 26rpx;
  color: rgba(255, 248, 240, 0.5);
  letter-spacing: 1rpx;
}

.invite-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 32rpx;
  background: rgba(26, 26, 46, 0.6);
  border-radius: 24rpx;
  border: 2rpx solid rgba(201, 169, 110, 0.2);
}

.code-label {
  font-size: 24rpx;
  color: var(--gold);
  opacity: 0.6;
  letter-spacing: 4rpx;
}

.code-display {
  display: flex;
  gap: 16rpx;
}

.code-text {
  font-size: 72rpx;
  color: var(--gold);
  font-weight: 700;
  letter-spacing: 16rpx;
  font-family: 'Courier New', monospace;
}

.code-tip {
  font-size: 22rpx;
  color: rgba(255, 248, 240, 0.3);
}

.generate-btn,
.join-btn {
  margin-top: 48rpx;
  padding: 28rpx 0;
  background: var(--gold);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.generate-btn .btn-text,
.join-btn .btn-text {
  font-size: 30rpx;
  color: var(--ink);
  font-weight: 600;
  letter-spacing: 4rpx;
}

.join-btn.disabled {
  opacity: 0.4;
}

.code-input-box {
  margin-top: 16rpx;
}

.code-inputs {
  display: flex;
  justify-content: center;
}

.code-input {
  width: 100%;
  height: 100rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.2);
  border-radius: 20rpx;
  text-align: center;
  font-size: 56rpx;
  color: var(--gold);
  font-weight: 700;
  letter-spacing: 24rpx;
  font-family: 'Courier New', monospace;
}

.loading-box {
  display: flex;
  justify-content: center;
  padding: 48rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--gold);
  opacity: 0.6;
}

.share-invite-btn {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.share-btn-inner {
  width: 100%;
  padding: 24rpx 0;
  background: transparent;
  border: 2rpx solid var(--gold);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.share-btn-inner::after {
  border: none;
}

.share-btn-inner .btn-text {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 500;
  letter-spacing: 4rpx;
}

.share-tip {
  font-size: 22rpx;
  color: rgba(255, 248, 240, 0.3);
}

.skip-section {
  margin-top: 64rpx;
  display: flex;
  justify-content: center;
}

.skip-text {
  font-size: 26rpx;
  color: rgba(255, 248, 240, 0.3);
  text-decoration: underline;
}
