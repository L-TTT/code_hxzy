.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 200rpx;
  background: rgba(15, 16, 35, 0.8);
  flex-shrink: 0;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-music {
  font-size: 28rpx;
  color: var(--ink);
}

.nav-title {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 600;
  letter-spacing: 4rpx;
  font-family: Georgia, serif;
}

.nav-right {
  padding: 16rpx;
}

.close-icon {
  font-size: 36rpx;
  color: rgba(201, 169, 110, 0.5);
}

.form-scroll {
  flex: 1;
  overflow: hidden;
}

.form-content {
  padding: 24rpx 32rpx;
}

.save-bar {
  display: flex;
  justify-content: flex-end;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(201, 169, 110, 0.1);
  margin-bottom: 24rpx;
}

.save-btn {
  padding: 16rpx 48rpx;
  background: var(--gold);
  border-radius: 32rpx;
}

.save-btn.disabled {
  opacity: 0.5;
}

.save-text {
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 600;
}

.form-section {
  margin-top: 40rpx;
}

.section-label {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 500;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  height: 88rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--cream);
  line-height: 88rpx;
  box-sizing: border-box;
}

.placeholder {
  color: rgba(255, 248, 240, 0.3);
}

.picker-display {
  height: 88rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--cream);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.picker-icon {
  font-size: 32rpx;
}

.form-textarea {
  min-height: 200rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--cream);
  width: 100%;
  box-sizing: border-box;
  line-height: 1.8;
}

.char-count {
  font-size: 24rpx;
  color: rgba(201, 169, 110, 0.4);
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

.type-grid {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.type-item.active {
  background: rgba(201, 169, 110, 0.15);
  border-color: var(--gold);
}

.type-emoji {
  font-size: 40rpx;
}

.type-name {
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.6);
}

.type-item.active .type-name {
  color: var(--gold);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 208rpx;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
}

.photo-thumb {
  width: 100%;
  height: 208rpx;
}

.photo-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 208rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(201, 169, 110, 0.3);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 107, 107, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

.photo-desc-input {
  height: 72rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  color: var(--cream);
  background: transparent;
}

.photo-desc-placeholder {
  color: rgba(255, 248, 240, 0.2);
  font-size: 22rpx;
}

.photo-add {
  width: 208rpx;
  height: 280rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(201, 169, 110, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 56rpx;
  color: var(--gold);
  opacity: 0.6;
}

.add-text {
  font-size: 22rpx;
  color: rgba(201, 169, 110, 0.5);
}

.location-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.location-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-icon {
  font-size: 40rpx;
}

.mt-16 {
  margin-top: 16rpx;
}

.music-file-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.music-file-btn {
  flex: 1;
  height: 88rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx dashed rgba(201, 169, 110, 0.3);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.music-file-icon {
  font-size: 32rpx;
}

.music-file-text {
  font-size: 26rpx;
  color: rgba(201, 169, 110, 0.6);
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.music-play-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(201, 169, 110, 0.15);
  border: 2rpx solid rgba(201, 169, 110, 0.3);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.music-play-icon {
  font-size: 32rpx;
  color: var(--gold);
}

.music-remove-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 107, 107, 0.1);
  border: 2rpx solid rgba(255, 107, 107, 0.3);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.music-remove-icon {
  font-size: 36rpx;
  color: rgba(255, 107, 107, 0.8);
}

.form-bottom {
  height: 200rpx;
}
