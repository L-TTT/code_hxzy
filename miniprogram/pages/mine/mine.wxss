.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding-left: 32rpx;
  background: rgba(15, 16, 35, 0.8);
  flex-shrink: 0;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-music {
  font-size: 28rpx;
  color: var(--ink);
}

.nav-title {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: 600;
  letter-spacing: 4rpx;
  font-family: Georgia, serif;
}

.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 110, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: var(--ink);
  font-weight: 300;
  line-height: 1;
}

.filter-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: rgba(15, 16, 35, 0.6);
  border-bottom: 2rpx solid rgba(201, 169, 110, 0.1);
  flex-shrink: 0;
}

.filter-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--ink-light);
  border: 2rpx solid rgba(201, 169, 110, 0.1);
  border-radius: 48rpx;
  transition: all 0.2s;
}

.filter-tag.active {
  background: rgba(201, 169, 110, 0.1);
  border-color: rgba(201, 169, 110, 0.2);
}

.filter-bars {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  width: 24rpx;
}

.filter-bars .bar {
  height: 3rpx;
  background: rgba(201, 169, 110, 0.6);
  border-radius: 2rpx;
}

.filter-text {
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.5);
}

.filter-tag.active .filter-text {
  color: var(--gold);
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-birthday {
  background: var(--coral);
  box-shadow: 0 0 16rpx rgba(255, 107, 107, 0.4);
}

.dot-anniversary {
  background: var(--rose);
  box-shadow: 0 0 16rpx rgba(183, 110, 121, 0.4);
}

.dot-daily {
  background: var(--lavender);
  box-shadow: 0 0 16rpx rgba(155, 142, 193, 0.4);
}

.timeline-area {
  flex: 1;
  overflow: hidden;
}

.timeline {
  position: relative;
  padding: 32rpx 32rpx 32rpx 80rpx;
}

.timeline-line {
  position: absolute;
  left: 39rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, rgba(201, 169, 110, 0.4), rgba(201, 169, 110, 0.1));
}

.timeline-item {
  position: relative;
  margin-bottom: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: -48rpx;
  top: 32rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.dot-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--ink);
}

.timeline-dot.dot-birthday {
  background: var(--coral);
}

.timeline-dot.dot-anniversary {
  background: var(--rose);
}

.timeline-dot.dot-daily {
  background: var(--lavender);
}

.timeline-content {
  flex: 1;
}

.year-label {
  margin-bottom: 16rpx;
}

.year-text {
  font-size: 24rpx;
  color: rgba(201, 169, 110, 0.6);
  letter-spacing: 8rpx;
  font-family: Georgia, serif;
}

.event-card {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8), rgba(37, 37, 64, 0.6));
  border: 2rpx solid rgba(201, 169, 110, 0.1);
  border-radius: 24rpx;
  padding: 28rpx;
  backdrop-filter: blur(10px);
}

.event-card:active {
  background: linear-gradient(135deg, rgba(37, 37, 64, 0.9), rgba(50, 50, 80, 0.7));
  border-color: rgba(201, 169, 110, 0.2);
}

.event-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.event-info {
  flex: 1;
}

.event-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 48rpx;
  font-size: 20rpx;
  margin-bottom: 12rpx;
}

.event-tag.birthday {
  background: rgba(255, 107, 107, 0.15);
  color: var(--coral);
  border: 2rpx solid rgba(255, 107, 107, 0.2);
}

.event-tag.anniversary {
  background: rgba(183, 110, 121, 0.15);
  color: var(--rose);
  border: 2rpx solid rgba(183, 110, 121, 0.2);
}

.event-tag.daily {
  background: rgba(155, 142, 193, 0.15);
  color: var(--lavender);
  border: 2rpx solid rgba(155, 142, 193, 0.2);
}

.tag-emoji {
  font-size: 20rpx;
}

.tag-text {
  font-size: 20rpx;
}

.event-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--cream);
  font-family: Georgia, serif;
}

.more-btn {
  padding: 8rpx;
}

.more-icon {
  font-size: 32rpx;
  color: rgba(201, 169, 110, 0.3);
}

.event-date {
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.5);
  margin-bottom: 20rpx;
  display: block;
}

.event-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.event-photos {
  display: flex;
  gap: 12rpx;
}

.mini-photo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.birthday-bg {
  background: rgba(255, 107, 107, 0.2);
}

.anniversary-bg {
  background: rgba(183, 110, 121, 0.2);
}

.daily-bg {
  background: rgba(155, 142, 193, 0.2);
}

.mini-emoji {
  font-size: 24rpx;
}

.mini-photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.event-music {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
}

.music-icon {
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.3);
}

.music-name {
  font-size: 20rpx;
  color: rgba(255, 248, 240, 0.3);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 88%;
  max-height: 80vh;
  background: var(--ink-light);
  border-radius: 32rpx;
  border: 2rpx solid rgba(201, 169, 110, 0.15);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid rgba(201, 169, 110, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gold);
  font-family: Georgia, serif;
}

.modal-close {
  padding: 8rpx;
}

.close-icon {
  font-size: 32rpx;
  color: rgba(255, 248, 240, 0.4);
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  max-height: 50vh;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 24rpx;
  color: rgba(201, 169, 110, 0.6);
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  display: block;
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: rgba(15, 16, 35, 0.4);
  border: 2rpx solid rgba(201, 169, 110, 0.08);
  border-radius: 16rpx;
}

.type-option.selected {
  background: rgba(201, 169, 110, 0.1);
  border-color: rgba(201, 169, 110, 0.3);
}

.type-emoji {
  font-size: 36rpx;
}

.type-name {
  font-size: 24rpx;
  color: rgba(255, 248, 240, 0.6);
}

.type-option.selected .type-name {
  color: var(--gold);
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(15, 16, 35, 0.4);
  border: 2rpx solid rgba(201, 169, 110, 0.08);
  border-radius: 16rpx;
  color: var(--cream);
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(15, 16, 35, 0.4);
  border: 2rpx solid rgba(201, 169, 110, 0.08);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  color: var(--cream);
}

.picker-arrow {
  font-size: 32rpx;
  color: rgba(255, 248, 240, 0.3);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx 24rpx;
  background: rgba(15, 16, 35, 0.4);
  border: 2rpx solid rgba(201, 169, 110, 0.08);
  border-radius: 16rpx;
  color: var(--cream);
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: rgba(255, 248, 240, 0.2);
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid rgba(201, 169, 110, 0.1);
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 248, 240, 0.05);
  border: 2rpx solid rgba(201, 169, 110, 0.1);
  border-radius: 48rpx;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  border-radius: 48rpx;
}

.btn-text {
  font-size: 28rpx;
}

.btn-cancel .btn-text {
  color: rgba(255, 248, 240, 0.6);
}

.btn-confirm .btn-text {
  color: var(--ink);
  font-weight: 600;
}